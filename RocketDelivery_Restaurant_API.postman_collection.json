        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Burger King\",\n  \"email\": \"contact@burgerking.com\",\n  \"phoneNumber\": \"555-1234\",\n  \"street\": \"789 Fast Food Blvd\",\n  \"city\": \"Metropolis\",\n  \"state\": \"NY\",\n  \"zipCode\": \"10001\",\n  \"country\": \"USA\",\n  \"description\": \"Fast food restaurant chain\",\n  \"isActive\": true\n}"
